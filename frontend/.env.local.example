# ========================================
# FIREBASE FRONTEND CONFIGURATION
# ========================================
# 
# How to get these values:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Click gear icon (Settings) ⚙️
# 4. Copy values from "Your apps" section
#
# IMPORTANT: Create .env.local file (NOT .env.local.example)
# Never commit .env.local to Git - it contains sensitive data
# ========================================

# Firebase Project Configuration
# Get from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=AIzaSyD_your_actual_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Optional: Measurement ID (can be left empty)
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend API URL
# Format: http://localhost:PORT or https://your-backend-domain.com
VITE_API_URL=http://localhost:5000

# ========================================
# Environment
# ========================================
# Keep this as development for local testing
VITE_ENV=development
